{
  "name": "gaterust-client-desktop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "description": "GateRust desktop client",
  "author": "jsryin",
  "license": "MIT",
  "repository": "https://github.com/jsryin/GateRust",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "pnpm check && electron-vite build",
    "package": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "7.0.2",
    "vite": "7.3.6"
  }
}
