!/config/*.sample.toml

# Runtime state, generated client configs, certificates, and logs
/data/
/var/
/run/
/logs/
/certs/
/acme/
/generated/
/client-configs/
*.log
*.pid
*.device-id

# Test and profiling output
*.profraw
*.profdata
*.lcov
/tarpaulin-report.html

# Local deployment artifacts
/dist-local/
/*.tar.gz
/*.tar.xz
/*.zip
/*.deb
/*.rpm
